# Odoo Connection
ODOO_URL=https://solviva-energy.odoo.com
ODOO_DB=solviva-energy
ODOO_USER=your.email@aboitizpower.com
ODOO_API_KEY=your_odoo_api_key_here

# Security — generate with: node -e "require('crypto').randomBytes(32).toString('hex').then?require('crypto').randomBytes(32).toString('hex'):require('crypto').randomBytes(32).toString('hex')"
HMAC_SECRET=generate_a_strong_random_secret_here

# Dashboard password
DASHBOARD_PASSWORD=change_this_to_a_strong_password

# Server port (default: 3001)
PORT=3001
